<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc admin-announce-title}"
    MinWidth="500">
    <GridContainer Columns="1">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
            <LineEdit Name="Announcer" Access="Public" PlaceHolder="{Loc admin-announce-announcer-placeholder}" Text="{Loc admin-announce-announcer-default}" HorizontalExpand="True" SizeFlagsStretchRatio="2"/>
            <Control HorizontalExpand="True" SizeFlagsStretchRatio="1" />
            <OptionButton Name="AnnounceMethod" Access="Public" HorizontalExpand="True" SizeFlagsStretchRatio="2"/>
        </BoxContainer>
        <TextEdit Name="Announcement" Access="Public" VerticalExpand="True" MinHeight="100" />

        <TabContainer Name="OptionsTabs" Access="Public">
            <BoxContainer Name="PresetsTab" Orientation="Horizontal" SeparationOverride="8">
                <Button Name="PresetEvilButton" Access="Public" Text="{Loc admin-announce-preset-evil}" HorizontalExpand="True" />
                <Button Name="PresetMercenaryButton" Access="Public" Text="{Loc admin-announce-preset-mercenary}" HorizontalExpand="True" />
                <Button Name="PresetSovietButton" Access="Public" Text="{Loc admin-announce-preset-soviet}" HorizontalExpand="True" />
            </BoxContainer>
            <BoxContainer Name="CustomTab" Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4">
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <Label Text="{Loc admin-announce-sound-label}" VerticalAlignment="Center" MinWidth="90"/>
                    <Control MinWidth="8" />
                    <OptionButton Name="SoundOption" Access="Public" HorizontalExpand="True"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <Label Text="{Loc admin-announce-color-label}" VerticalAlignment="Center" MinWidth="90"/>
                    <Control MinWidth="8" />
                    <OptionButton Name="ColorOption" Access="Public" HorizontalExpand="True"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <Label Text="{Loc admin-announce-font-label}" VerticalAlignment="Center" MinWidth="90"/>
                    <Control MinWidth="8" />
                    <OptionButton Name="FontOption" Access="Public" HorizontalExpand="True"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <Label Text="{Loc admin-announce-font-size-label}" VerticalAlignment="Center" MinWidth="90"/>
                    <Control MinWidth="8" />
                    <OptionButton Name="FontSizeOption" Access="Public" HorizontalExpand="True"/>
                </BoxContainer>
                <CheckBox Name="IncludeAnnouncementSuffix" Access="Public" Text="{Loc admin-announce-include-suffix}" Pressed="True" />
            </BoxContainer>
        </TabContainer>

        <GridContainer Rows="1">
            <CheckBox Name="KeepWindowOpen" Access="Public" Text="{Loc 'admin-announce-keep-open'}" />
            <Button Name="AnnounceButton" Access="Public" Disabled="True" Text="{Loc admin-announce-button}" HorizontalAlignment="Center"/>
        </GridContainer>
    </GridContainer>
</DefaultWindow>
